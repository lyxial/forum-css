@import url('https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap');

.apv2-fiche {
  width: 700px;
  max-width: 700px;
  margin: 30px auto;
  padding: 12px;
  background: #070622;
  color: #17164e;
  font-family: Georgia, "Times New Roman", serif;
  box-sizing: border-box;
}

.apv2-fiche * {
  box-sizing: border-box;
}

.apv2-card {
  background: #ffffff;
  border: 1px solid #dedaf4;
  border-radius: 16px;
  padding: 22px 18px 18px;
}

.apv2-top {
  text-align: center;
}

.apv2-label {
  color: #817bc8;
  font: 700 12px Arial, sans-serif;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.apv2-name {
  margin: 8px 0 4px;
  color: #111047;
  font-family: "Great Vibes", cursive;
  font-size: 58px;
  line-height: .9;
}

.apv2-citation {
  color: #111047;
  font-size: 12px;
  font-weight: bold;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.apv2-tabs input {
  display: none;
}

.apv2-nav {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  margin-top: 28px;
}

.apv2-nav label {
  position: relative;
  height: 52px;
  border: 1px solid #d8d3f1;
  border-radius: 8px 8px 0 0;
  background: #f1effb;
  color: #5f59a9;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font: 700 11px Arial, sans-serif;
  text-transform: uppercase;
  cursor: pointer;
}

#apv2-info:checked ~ .apv2-nav label[for="apv2-info"],
#apv2-facts:checked ~ .apv2-nav label[for="apv2-facts"],
#apv2-story:checked ~ .apv2-nav label[for="apv2-story"] {
  background: linear-gradient(135deg, #15104e, #2a1a82);
  color: #ffffff;
}

#apv2-info:checked ~ .apv2-nav label[for="apv2-info"]:after,
#apv2-facts:checked ~ .apv2-nav label[for="apv2-facts"]:after,
#apv2-story:checked ~ .apv2-nav label[for="apv2-story"]:after {
  content: "";
  position: absolute;
  bottom: -10px;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-top: 10px solid #21156d;
}

.apv2-panels {
  border: 1px solid #d8d3f1;
  border-radius: 0 0 10px 10px;
  padding: 34px 26px;
}

.apv2-panel {
  display: none;
}

#apv2-info:checked ~ .apv2-panels .apv2-panel-info,
#apv2-facts:checked ~ .apv2-panels .apv2-panel-facts,
#apv2-story:checked ~ .apv2-panels .apv2-panel-story {
  display: block;
}

.apv2-title {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin: 6px 0 26px;
  color: #111047;
  font: 700 16px Arial, sans-serif;
  text-transform: uppercase;
}

.apv2-title:before,
.apv2-title:after {
  content: "";
  width: 130px;
  height: 1px;
  background: #d8d3f1;
}

.apv2-title span:before,
.apv2-title span:after {
  content: "✣";
  color: #918bd3;
  margin: 0 10px;
}

.apv2-intro {
  margin: -10px auto 26px;
  color: #4f4aa0;
  text-align: center;
  font-style: italic;
  line-height: 1.6;
}

.apv2-grid-info {
  display: grid;
  grid-template-columns: 210px 1fr;
  gap: 28px;
}

.apv2-two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
}

.apv2-imgbox {
  min-height: 260px;
  border: 1px dashed #c9c4ec;
  border-radius: 8px;
  background: #fbfaff;
  color: #817bc8;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font: 700 13px Arial, sans-serif;
  text-transform: uppercase;
}

.apv2-imgbox small {
  display: block;
  margin-top: 7px;
  color: #6e68b5;
  font: italic 14px Georgia, serif;
  text-transform: none;
}

.apv2-imgicon {
  display: block;
  margin-bottom: 10px;
  font-size: 44px;
}

.apv2-fields {
  display: grid;
  gap: 10px;
}

.apv2-field {
  display: grid;
  grid-template-columns: 22px auto 1fr;
  gap: 8px;
  align-items: center;
  padding-bottom: 7px;
  border-bottom: 1px dashed #ddd9f2;
  color: #514ca0;
  font-size: 13px;
}

.apv2-field i {
  color: #817bc8;
  font-style: normal;
}

.apv2-field b {
  color: #111047;
  font-family: Arial, sans-serif;
  text-transform: uppercase;
}

.apv2-lines {
  min-height: 265px;
  border: 1px solid #d8d3f1;
  border-radius: 8px;
  padding: 28px 24px;
  background:
    repeating-linear-gradient(to bottom, transparent 0 34px, #e7e4f7 35px),
    #ffffff;
  color: #514ca0;
  line-height: 1.9;
}

.apv2-quote-box {
  position: relative;
  margin: 20px 0 38px;
  padding: 28px 70px;
  border: 1px solid #d8d3f1;
  border-radius: 8px;
  background: #f6f4fc;
  color: #514ca0;
  text-align: center;
  font-size: 16px;
  line-height: 1.7;
}

.apv2-quote-box:before,
.apv2-quote-box:after {
  position: absolute;
  color: #918bd3;
  font-size: 42px;
}

.apv2-quote-box:before {
  content: "“";
  left: 46px;
  top: 22px;
}

.apv2-quote-box:after {
  content: "”";
  right: 46px;
  bottom: 8px;
}

.apv2-list {
  margin: 0;
  padding: 0;
  list-style: none;
}

.apv2-list li {
  position: relative;
  padding: 7px 0 7px 28px;
  border-bottom: 1px dashed #ddd9f2;
  color: #514ca0;
  font-size: 14px;
}

.apv2-list li:before {
  content: "★";
  position: absolute;
  left: 0;
  color: #817bc8;
}

.apv2-bars {
  display: grid;
  gap: 14px;
}

.apv2-bar {
  display: grid;
  grid-template-columns: 38px 1fr 38px;
  gap: 12px;
  align-items: center;
}

.apv2-bar-icon {
  width: 36px;
  height: 36px;
  border-radius: 6px;
  background: #111047;
  color: #fff;
  display: grid;
  place-items: center;
}

.apv2-bar-label {
  color: #111047;
  font: 700 12px Arial, sans-serif;
  text-transform: uppercase;
}

.apv2-track {
  height: 10px;
  margin-top: 5px;
  border-radius: 20px;
  background: #eceaf3;
  overflow: hidden;
}

.apv2-fill {
  height: 100%;
  border-radius: 20px;
  background: linear-gradient(90deg, #8b82d5, #b6adeb);
}

.apv2-about {
  border: 1px solid #d8d3f1;
  border-radius: 8px;
  padding: 22px;
  color: #514ca0;
  line-height: 1.7;
}

.apv2-footer {
  margin-top: 16px;
  color: #b7b2e7;
  text-align: center;
  font-size: 15px;
}

.apv2-footer strong {
  display: block;
  margin-top: 6px;
  font-size: 18px;
  font-weight: normal;
}

