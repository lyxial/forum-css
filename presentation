  grid-template-columns: 310px 1fr !important;
  grid-template-rows: 92px auto 1fr auto !important;
  width: 940px !important;
  max-width: 96% !important;
  margin-left: auto !important;
  margin-right: auto !important;
  background: #51475c !important;
  border: 1px solid #453a51 !important;
  overflow: hidden !important;
}

.post.apv2-fiche-post .aurora-profile-strip {
  display: grid !important;
}

.post.apv2-fiche-post .postprofile {
  display: block !important;
  grid-column: 1 !important;
  grid-row: 2 / 5 !important;
}

.post.apv2-fiche-post .post-head {
  display: grid !important;
  grid-column: 2 !important;
  grid-row: 2 !important;
  width: 100% !important;
